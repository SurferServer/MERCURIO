# ── MERCURIO — Environment Variables ──────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit the .env file!

# Database (SQLite per sviluppo, PostgreSQL per produzione)
DATABASE_URL=sqlite:///./content_hub.db
# DATABASE_URL=postgresql://user:password@localhost:5432/content_hub

# Required: secret key for JWT token signing (use a long random string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MERCURIO_JWT_SECRET=change_me_to_a_random_64_char_hex_string

# JWT token expiry in hours (default: 24)
MERCURIO_JWT_EXPIRE_HOURS=24

# Max upload file size in MB (default: 50)
MERCURIO_MAX_UPLOAD_MB=50

# Environment: "production" disables /docs endpoint
MERCURIO_ENV=production

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Directory per i file caricati
UPLOAD_DIR=./uploads

# Google Drive (opzionale)
# GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials/drive-key.json
# GOOGLE_DRIVE_ROOT_FOLDER_ID=1ABC...xyz
